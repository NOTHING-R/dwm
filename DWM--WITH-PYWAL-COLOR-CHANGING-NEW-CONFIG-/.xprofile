#!/bin/bash

# ── Input ─────────────────────────────────────────────────────
xinput set-prop "SYNA3071:00 06CB:82F1 Touchpad" "libinput Tapping Enabled" 1
xinput set-prop "SYNA3071:00 06CB:82F1 Touchpad" "libinput Natural Scrolling Enabled" 1

# ── Restore wal colorscheme FIRST (before apps launch) ────────
(cat ~/.cache/wal/sequences) # restore terminal colors (blocking, fast)
wal -R                       # restore full colorscheme + wallpaper

# ── System tray & compositor ──────────────────────────────────
picom &
dwmblocks &
dunst &
nm-applet &
blueman-applet &
flameshot &

# ── Emacs daemon ──────────────────────────────────────────────
pgrep -x emacs >/dev/null || emacs --daemon &

# ── IBus input method ─────────────────────────────────────────
ibus-daemon -drx

